# Application
APP_ENV=development
APP_PORT=8085

# Database — Render auto-injects DATABASE_URL
DATABASE_URL=postgres://user:password@localhost:5432/neurostream_db

# Analytics Config
TIMESTAMP_BUCKET_SECONDS=5
MIN_REVISIT_COUNT=2
TOP_HIGHLIGHTS_COUNT=5
IMPORTANT_SECTIONS_COUNT=10

# Internal Auth (shared secret with MS4)
INTERNAL_API_SECRET=your_shared_internal_secret
