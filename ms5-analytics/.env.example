# Application
APP_ENV=development
APP_PORT=8085

# Database — defaults to local SQLite, set to PostgreSQL for production
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neurostream_db
DATABASE_URL=sqlite+aiosqlite:///./ms5_analytics.db

# Analytics Config
TIMESTAMP_BUCKET_SECONDS=5
MIN_REVISIT_COUNT=2
TOP_HIGHLIGHTS_COUNT=5
IMPORTANT_SECTIONS_COUNT=10

# Internal Auth (shared secret with MS4)
INTERNAL_API_SECRET=your_shared_internal_secret
