# Redis
REDIS_URL=redis://redis:6379
REDIS_QUEUE_NAME=media_processing_jobs

# S3 credentials / endpoint
# Production aliases accepted by MS1:
# S3_REGION, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, AWS_S3_BUCKET, AWS_ENDPOINT_URL
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=neurostream-media
S3_ENDPOINT=http://minio:9000


# S3 Path Prefixes
S3_RAW_PREFIX=raw-uploads
S3_PROCESSED_PREFIX=processed

# FFmpeg Settings
CHUNK_DURATION_SECONDS=30
FRAME_SAMPLE_FPS=1
AUDIO_FORMAT=wav

# Worker Pool
WORKER_COUNT=5

# MS4 Callback
MS4_CALLBACK_URL=http://ms4-service:4000/internal/job-status

# Temp Storage
TEMP_DIR=/tmp/neurostream

# Server
SERVER_PORT=8081
