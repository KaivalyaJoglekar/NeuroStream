# Redis (hosted Redis Cloud recommended)
# Example: rediss://default:<password>@<host>:<port>/0
REDIS_URL=rediss://default:your-redis-password@your-redis-host:19011/0
REDIS_QUEUE_NAME=media_processing_jobs

# S3 credentials / endpoint (Backblaze B2 S3-compatible example)
# Production aliases accepted by MS1:
# S3_REGION, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, AWS_S3_BUCKET, AWS_ENDPOINT_URL
AWS_REGION=us-east-005
AWS_ACCESS_KEY_ID=your-backblaze-key-id
AWS_SECRET_ACCESS_KEY=your-backblaze-application-key
S3_BUCKET_NAME=claritycheck
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# Local-only alternatives (if using docker compose --profile local-infra)
# REDIS_URL=redis://redis:6379
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET_NAME=neurostream-media
# S3_ENDPOINT=http://minio:9000


# S3 Path Prefixes
S3_RAW_PREFIX=raw-uploads
S3_PROCESSED_PREFIX=processed

# FFmpeg Settings
CHUNK_DURATION_SECONDS=30
FRAME_SAMPLE_FPS=1
AUDIO_FORMAT=wav

# Worker Pool
WORKER_COUNT=5

# Internal callback auth key expected by MS4 /internal/job-status
INTERNAL_API_KEY=ms4-internal-api-key-change-in-production

# MS4 Callback
MS4_CALLBACK_URL=https://neurostream-00qg.onrender.com/internal/job-status

# Temp Storage
TEMP_DIR=/tmp/neurostream

# Server
SERVER_PORT=8081
