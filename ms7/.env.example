# MS7 — PDF Export Service
# Copy to .env and fill in your values

# ── AWS S3 (dedicated export bucket — separate from all other ms buckets) ──
# Alias support: S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, S3_REGION, AWS_S3_BUCKET
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_EXPORT_BUCKET=neurostream-exports

# ── Presigned URL expiry (seconds) — default 1 hour ──
PRESIGNED_URL_EXPIRY=3600

# ── Server ──
PORT=8007

# ── RabbitMQ ──
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
ENABLE_RABBITMQ_CONSUMER=false
