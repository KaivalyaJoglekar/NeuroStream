# MS6 environment variables — copy to .env

# ── MS3 Connection ────────────────────────────────────
MS3_BASE_URL=http://localhost:8003
MS3_DEFAULT_LIMIT=10

# ── Gemini API ────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=4096

# ── S3-compatible Storage (Backblaze/Filebase) ───────
# Optional for current MS6 runtime (kept for cloud deployment alignment)
AWS_REGION=us-east-1
AWS_ENDPOINT=
AWS_BUCKET_NAME=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_PATH_STYLE=true

# ── Agent Tuning (optional overrides) ─────────────────
# RESEARCH_MAX_ITERATIONS=5
# SUMMARIZE_WINDOW_SECONDS=300
