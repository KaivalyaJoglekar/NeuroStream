# FastAPI Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neurostream

# Redis
REDIS_URL=redis://localhost:6379

# Backblaze B2 (S3-Compatible)
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
B2_PORT=443
B2_USE_SSL=true
B2_KEY_ID=your-backblaze-key-id
B2_APPLICATION_KEY=your-backblaze-application-key
B2_BUCKET=neurostream-videos
B2_REGION=us-west-004

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Internal API
INTERNAL_API_KEY=ms4-internal-api-key-change-in-production
MS5_BASE_URL=http://localhost:8085
MS5_INTERNAL_SECRET=your_shared_internal_secret

# CORS
CORS_ORIGIN=http://localhost:3000
