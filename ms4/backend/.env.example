# FastAPI Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neurostream

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3 (or any S3-compatible storage)
AWS_ENDPOINT_URL=
S3_PORT=443
S3_USE_SSL=true
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
AWS_S3_BUCKET=neurostream-videos
S3_REGION=us-east-1

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Internal API
INTERNAL_API_KEY=ms4-internal-api-key-change-in-production
MS5_BASE_URL=http://localhost:8085
MS5_INTERNAL_SECRET=your_shared_internal_secret

# CORS
CORS_ORIGIN=http://localhost:3000
