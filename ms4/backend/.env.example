# FastAPI Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neurostream

# Redis
REDIS_URL=redis://localhost:6379

# MinIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=neurostream-videos

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Internal API
INTERNAL_API_KEY=ms4-internal-api-key-change-in-production
MS5_BASE_URL=http://localhost:8085
MS5_INTERNAL_SECRET=your_shared_internal_secret

# CORS
CORS_ORIGIN=http://localhost:3000
